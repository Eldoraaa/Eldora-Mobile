{
  "expo": {
    "name": "Eldora",
    "slug": "eldora",
    "version": "1.0.0",
    "scheme": "eldora",
    "orientation": "portrait",
    "icon": "./assets/images/eldora_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/eldora_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eldora.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/eldora_logo.png",
        "backgroundColor": "#FDF8F5"
      },
      "package": "com.eldora.app",
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/eldora_logo.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDF8F5",
          "image": "./assets/images/eldora_logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#FDF8F5",
            "image": "./assets/images/eldora_logo.png",
            "imageWidth": 180
          },
          "ios": {
            "backgroundColor": "#FDF8F5",
            "image": "./assets/images/eldora_logo.png",
            "resizeMode": "contain"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
